    "audit:live-data-flow": "tsx src/server/scripts/audit-live-data-flow.ts",
    "trace:meta-api-read": "tsx src/server/scripts/trace-meta-api-read.ts",
    "trace:store-api-read": "tsx src/server/scripts/trace-store-api-read.ts"
  },
