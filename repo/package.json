{
  "name": "meta-ads-store-analytics-mcp",
  "version": "0.1.0",
  "description": "Read-only Meta Ads MCP server for multi-store analytics, based on byadsco/meta-ads-mcp.",
  "type": "module",
  "engines": {
    "node": ">=20.10.0"
  },
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc && vite build --config apps/web/vite.config.ts",
    "build:server": "tsc",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "prisma:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "repair:order-timezones": "node dist/src/scripts/repair-order-timezones.js",
    "repair:order-timezones:dev": "tsx scripts/repair-order-timezones.ts",
    "db:studio": "prisma studio",
    "start": "node dist/apps/api/src/index.js",
    "start:api": "node dist/apps/api/src/index.js",
    "start:worker": "node dist/apps/worker/src/index.js",
    "start:mcp": "node dist/apps/mcp/src/index.js",
    "start:stdio": "node dist/src/index.js --transport stdio",
    "dev": "tsx src/index.ts",
    "dev:stdio": "tsx src/index.ts --transport stdio",
    "verify:readonly": "node scripts/verify-readonly.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^6.0.0",
    "axios": "^1.17.0",
    "cors": "^2.8.5",
    "dayjs": "^1.11.21",
    "express": "^5.2.1",
    "lucide-react": "^0.546.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.2.0",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "mcp",
    "meta-ads",
    "facebook-ads",
    "read-only",
    "shopline",
    "shoplazza"
  ],
  "license": "MIT"
}
