# First-phase read-only Meta Ads MCP configuration.
# Copy to .env and fill values. Never commit real secrets.

NODE_ENV=production
READ_ONLY_MODE=true
SERVER_URL=https://your-domain.example.com
PORT=3000
REDIS_URL=redis://redis:6379
CACHE_DRIVER=redis

# PostgreSQL. docker-compose provides a local postgres service by default.
POSTGRES_DB=meta_ads_analytics
POSTGRES_USER=meta_ads
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DATABASE_URL=postgresql://meta_ads:CHANGE_THIS_STRONG_PASSWORD@postgres:5432/meta_ads_analytics?schema=public

# Service-to-service MCP auth.
# API_KEY is supported for the requested deployment naming.
API_KEY=
# MCP_API_KEY is kept for compatibility with the upstream project.
MCP_API_KEY=

# Admin backend login.
ADMIN_USERNAME=
ADMIN_PASSWORD=
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# Meta token source. Use a System User token with read permissions only.
META_ACCESS_TOKEN=
# Optional multi-token JSON: {"store_a":"META_TOKEN_VALUE","store_b":"META_TOKEN_VALUE"}
META_TOKENS=
META_API_VERSION=v25.0

# CORS must be explicit. Do not use * in production.
CORS_ALLOWED_ORIGINS=https://claude.ai

# Required for encrypted store tokens.
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# Store read-only API adapters. Built-in defaults follow the official private-app APIs.
# Paths and headers are optional advanced overrides.
SHOPLINE_API_VERSION=v20240301
SHOPLAZZA_API_VERSION=2025-06
SHOPLINE_ORDERS_PATH=
SHOPLAZZA_ORDERS_PATH=
SHOPLINE_PROFILE_PATH=
SHOPLAZZA_PROFILE_PATH=
SHOPLINE_TOKEN_HEADER=Authorization
SHOPLAZZA_TOKEN_HEADER=access-token
SHOPLINE_TOKEN_HEADER_VALUE=Bearer {token}
SHOPLAZZA_TOKEN_HEADER_VALUE={token}

# Optional built-in scheduler. Keep disabled when running multiple app replicas
# unless you move scheduling to one dedicated worker process. docker-compose
# starts a dedicated worker service, so API scheduler can usually stay false.
SYNC_SCHEDULER_ENABLED=false
WORKER_ENABLED=true
WORKER_CONCURRENCY=1
SYNC_START_DELAY_SECONDS=30
ORDER_SYNC_ENABLED=true
ORDER_SYNC_INTERVAL_MINUTES=60
ORDER_SYNC_LOOKBACK_DAYS=7
ORDER_SYNC_LIMIT=100
META_AD_ACCOUNTS_SYNC_ENABLED=true
META_AD_ACCOUNTS_SYNC_INTERVAL_MINUTES=360
META_AD_ACCOUNTS_ACTIVE_LAST_DAYS=90
META_AD_ACCOUNTS_SYNC_LIMIT=500
META_STRUCTURE_SYNC_ENABLED=true
META_STRUCTURE_SYNC_INTERVAL_MINUTES=360
META_STRUCTURE_SYNC_LIMIT=500
META_STRUCTURE_SYNC_MAX_PAGES=10
META_CREATIVES_SYNC_ENABLED=false
META_CREATIVES_SYNC_INTERVAL_MINUTES=720
META_CREATIVES_SYNC_LIMIT=250
META_CREATIVES_SYNC_MAX_PAGES=10
META_INSIGHTS_SYNC_ENABLED=true
META_INSIGHTS_SYNC_INTERVAL_MINUTES=60
META_INSIGHTS_SYNC_DAYS=30
META_INSIGHTS_SYNC_MAX_PAGES=10
META_INSIGHTS_SYNC_ACCOUNT_LIMIT=50
META_INSIGHTS_SYNC_UNMAPPED_ACCOUNTS=true
# Sync age/gender/placement breakdowns into meta_breakdowns for AI audience and placement analysis.
META_BREAKDOWN_SYNC_ENABLED=true
RULE_MONITOR_ENABLED=true
RULE_MONITOR_INTERVAL_MINUTES=60
FAILED_SYNC_RETRY_ENABLED=true
FAILED_SYNC_RETRY_INTERVAL_MINUTES=60
FAILED_SYNC_RETRY_LIMIT=10

# AI provider keys are configured from the admin/API and encrypted in database.
# These env values only document the default model names used when a provider
# setting omits a model.
DEFAULT_OPENAI_CHAT_MODEL=gpt-4o-mini
DEFAULT_GEMINI_CHAT_MODEL=gemini-1.5-flash

LOG_LEVEL=info
