generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model AdInsight {
  id               Int      @id @default(autoincrement())
  accountId        String
  level            String   @default("account")
  campaignId       String   @default("")
  adsetId          String   @default("")
  adId             String   @default("")
  date             String
  accountName      String
  reach            Int      @default(0)
  impressions      Int      @default(0)
  clicks           Int      @default(0)
  spend            Float    @default(0)
  addToCart        Int      @default(0)
  initiateCheckout Int      @default(0)
  purchases        Int      @default(0)
  purchaseValue    Float    @default(0)
  cpc              Float    @default(0)
  ctr              Float    @default(0)
  atcRate          Float    @default(0)
  checkoutRate     Float    @default(0)
  cpp              Float    @default(0)
  roas             Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([accountId, level, campaignId, adsetId, adId, date])
}

model Setting {
  key   String @id
  value String
}

model AccountMapping {
  id          Int      @id @default(autoincrement())
  storeId     Int?
  fbAccountId String   @unique
  fbPageId    String?
  project     String?
  owner       String?
  name        String?
  mode        String?  @default("automatic")
  store       Store?   @relation(fields: [storeId], references: [id], onDelete: SetNull)
  updatedAt   DateTime @updatedAt
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("member") // "admin" or "member"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invitation {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  token     String   @unique
  role      String   @default("member")
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Store {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  platform        String?          @default("shopline")
  shopline_token  String?
  shopify_token   String?
  shoplazza_token String?
  domain          String?
  visitors        Int              @default(0)
  timezone        String?          @default("GMT+8")
  mode            String?          @default("sandbox")
  accounts        AdAccount[]
  accountMappings AccountMapping[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model MetaAccountMonitoring {
  accountId     String   @id
  accountName   String?
  status        Int?
  spendCap      Float?
  amountSpent   Float?
  balance       Float?
  currency      String?
  timezone      String?
  updatedAt     DateTime @updatedAt
}

model AdAccount {
  id              Int      @id @default(autoincrement())
  fb_account_id   String   @unique
  fb_account_name String?
  fb_access_token String?
  storeId         Int?
  activityStatus  Int      @default(2)
  status            String?   @default("1")
  recentActivity90d Boolean   @default(false)
  currency          String?   @default("USD")
  timezone          String?   @default("GMT+8")
  lastActivityCheckedAt DateTime?
  store           Store?   @relation(fields: [storeId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  campaigns       Campaign[]
}

model Product {
  id          String   @id
  storeId     Int
  name        String
  sku         String
  category    String
  inventory   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id              String   @id
  storeId         Int
  productId       String
  revenue         Float    @default(0)
  profit          Float    @default(0)
  refunded        Boolean  @default(false)
  refundedAt      DateTime?
  orderId         String?
  orderTotal      Float?
  createdAt       DateTime @default(now())
  created_at_utc  DateTime?
  store_timezone  String?
  store_local_date String?
  store_local_datetime String?
  paymentStatus     String?   @default("paid")
  fulfillmentStatus String?   @default("fulfilled")
}

model Campaign {
  id          String   @id
  accountId   String
  name        String
  region      String?
  status      String?
  adAccount   AdAccount? @relation(fields: [accountId], references: [fb_account_id], onDelete: Cascade)
  adSets      AdSet[]
}

model AdSet {
  id          String   @id
  campaignId  String
  accountId   String
  name        String
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ads         Ad[]
}

model Ad {
  id          String   @id
  adsetId     String
  campaignId  String
  accountId   String
  name        String
  creativeId  String?
  adSet       AdSet?    @relation(fields: [adsetId], references: [id], onDelete: Cascade)
  creative    AdCreative? @relation(fields: [creativeId], references: [creativeId], onDelete: SetNull)
}

model AdCreative {
  creativeId   String                     @id
  fbAccountId  String
  mediaType    String                     // IMAGE/VIDEO
  imageUrl     String?
  videoId      String?
  videoHash    String?
  imageHash    String?                    @unique
  storeId      Int?
  name         String?
  type         String?
  landingUrl   String?
  previewUrl   String?
  metaAssetId  String?
  hookRate     Float                      @default(0)
  ads          Ad[]
  creativePerformanceDaily CreativePerformanceDaily[]
}

model ProductPerformanceDaily {
  id               Int      @id @default(autoincrement())
  date             String
  storeId          Int
  productId        String
  productName      String
  sku              String
  category         String
  revenue          Float    @default(0)
  orders           Int      @default(0)
  profit           Float    @default(0)
  adSpend          Float    @default(0)
  productRoas      Float    @default(0)
  profitRoas       Float    @default(0)
  ctr              Float    @default(0)
  cpc              Float    @default(0)
  cpm              Float    @default(0)
  frequency        Float    @default(0)
  refundRate       Float    @default(0)
  inventory        Int      @default(0)
  topRegion        String?
  topCampaign      String?
  topCreative      String?
  aiRiskStatus     String?
  trendStatus      String?
  aiSuggestion     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([storeId, productId, date])
}


model FactMetaPerformance {
  id             Int       @id @default(autoincrement())
  date           String
  level          String
  account_id     String
  campaign_id    String    @default("")
  adset_id       String    @default("")
  ad_id          String    @default("")
  creative_id    String    @default("")
  entity_id      String
  spend          Float     @default(0)
  impressions    Int       @default(0)
  clicks         Int       @default(0)
  ctr            Float     @default(0)
  cpc            Float     @default(0)
  cpm            Float     @default(0)
  purchases      Int       @default(0)
  purchase_value Float     @default(0)
  roas           Float     @default(0)
  currency       String?   @default("USD")
  synced_at      DateTime? @default(now())
  raw_payload    String?

  @@unique([date, level, account_id, entity_id], name: "date_level_account_id_entity_id")
  @@index([account_id])
  @@index([date])
}

model DailySummary {
  id        String   @id @default(cuid())
  scope     String
  scopeId   String
  date      String
  metrics   String
  spend     Float    @default(0)
  impressions Int    @default(0)
  clicks    Int    @default(0)
  revenue   Float    @default(0)
  orders    Int    @default(0)
  roas      Float    @default(0)
  metaRoas  Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scope, scopeId, date])
}

model SyncLog {
  id             String    @id @default(cuid())
  type           String
  status         String    @default("pending")
  storeId        Int?
  adAccountId    String?
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  rangeStart     DateTime?
  rangeEnd       DateTime?
  recordsFetched Int       @default(0)
  recordsSaved   Int       @default(0)
  errorMessage   String?
  metadata       String?
  taskType       String?
  sourceType     String?
  fbtraceId      String?
  triggeredBy    String?
  taskChainId    String?
  error          String?
}

model AiProviderSetting {
  id              Int     @id @default(autoincrement())
  provider        String
  displayName     String
  apiKeyEncrypted String
  defaultChatModel String?
  defaultAnalysisModel String?
  defaultCreativeModel String?
  enabled         Boolean @default(true)
  priority        Int     @default(100)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([provider, displayName])
}

model AiConversation {
  id        String   @id @default(cuid())
  title     String?
  context   String?
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  AiMessage[]
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String
  role           String
  content        String
  metadata       String?
  createdAt      DateTime       @default(now())
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model AiAnalysisReport {
  id                String               @id @default(cuid())
  type              String
  entityType        String
  entityId          String
  dateRange         String?
  conclusion        String
  dataBasis         String
  riskPoints        String
  priority          Int                  @default(3)
  observationWindow String?
  model             String?
  metadata          String?
  createdAt         DateTime             @default(now())
  suggestions       AiActionSuggestion[]
}

model AiActionSuggestion {
  id                 String           @id @default(cuid())
  reportId           String
  action             String
  rationale          String
  priority           Int              @default(3)
  status             String           @default("pending")
  executionChecklist String?
  metadata           String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  report             AiAnalysisReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model FactAudienceBreakdown {
  id                         Int      @id @default(autoincrement())
  date                       String
  level                      String
  account_id                 String
  dimension_type             String
  dimension_value            String
  dimension_value_secondary   String   @default("")
  campaign_id                String   @default("")
  adset_id                   String   @default("")
  ad_id                      String   @default("")
  spend                      Float    @default(0)
  impressions                Int      @default(0)
  clicks                     Int      @default(0)
  purchases                  Int      @default(0)
  purchase_value             Float    @default(0)
  synced_at                  DateTime @default(now())
  raw_payload                String?

  @@unique([date, level, account_id, dimension_type, dimension_value, dimension_value_secondary, campaign_id, adset_id, ad_id], name: "date_level_account_id_dimension_type_dimension_value_dimension_value_secondary_campaign_id_adset_id_ad_id")
  @@index([account_id])
  @@index([date])
}

model CreativePerformanceDaily {
  id               Int        @id @default(autoincrement())
  creativeId       String
  date             String
  spend            Float      @default(0)
  impressions      Int        @default(0)
  clicks           Int        @default(0)
  revenue          Float      @default(0)
  storeId          Int?
  creativeName     String?
  type             String?
  purchases        Int        @default(0)
  roas             Float      @default(0)
  ctr              Float      @default(0)
  cpc              Float      @default(0)
  cpm              Float      @default(0)
  frequency        Float      @default(0)
  hookRate         Float      @default(0)
  aiRiskStatus     String?
  trendStatus      String?
  aiSuggestion     String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  creative         AdCreative @relation(fields: [creativeId], references: [creativeId], onDelete: Cascade)

  @@unique([creativeId, date])
  @@index([creativeId, date])
}

model DataCenterStoreDaily {
  id                String   @id @default(cuid())

  storeId           Int
  storeName         String?
  platform          String?
  domain            String?

  date              String
  timezone          String
  currency          String   @default("USD")

  orderCount        Int      @default(0)
  grossSales        Float    @default(0)
  netSales          Float    @default(0)
  aov               Float    @default(0)

  amountSource      String?
  orderIdsJson      String?
  rawDigestJson     String?
  apiRawDigestJson  String?
  diagnosticsJson   String?

  apiFetchedAt      DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([storeId, date])
  @@index([storeId])
  @@index([date])
}

model DataCenterMetaAccountDaily {
  id                String   @id @default(cuid())

  accountId         String
  accountName       String?
  storeId           Int?
  storeName         String?

  date              String
  timezone          String?
  currency          String   @default("USD")

  spend             Float    @default(0)
  impressions       Int      @default(0)
  reach             Int      @default(0)
  clicks            Int      @default(0)
  ctr               Float    @default(0)
  cpc               Float    @default(0)
  cpm               Float    @default(0)

  purchases         Int      @default(0)
  purchaseValue     Float    @default(0)
  roas              Float    @default(0)

  rawPayloadJson    String?
  diagnosticsJson   String?

  apiFetchedAt      DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([accountId, date])
  @@index([accountId])
  @@index([storeId])
  @@index([date])
}

model DataCenterRefreshRun {
  id                String   @id @default(cuid())

  type              String
  scope             String?
  startDate         String
  endDate           String
  status            String

  recordsFetched    Int      @default(0)
  recordsSaved      Int      @default(0)
  recordsUpdated    Int      @default(0)

  error             String?
  diagnosticsJson   String?

  startedAt         DateTime @default(now())
  finishedAt        DateTime?
}
