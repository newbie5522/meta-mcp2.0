generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model AdInsight {
  id               Int      @id @default(autoincrement())
  accountId        String
  level            String   @default("account") // "account" | "campaign" | "adset" | "ad"
  campaignId       String   @default("")
  adsetId          String   @default("")
  adId             String   @default("")
  date             String
  accountName      String
  reach            Int      @default(0)
  impressions      Int      @default(0)
  clicks           Int      @default(0)
  spend            Float    @default(0)
  addToCart        Int      @default(0)
  initiateCheckout Int      @default(0)
  purchases        Int      @default(0)
  purchaseValue    Float    @default(0)
  cpc              Float    @default(0)
  ctr              Float    @default(0)
  atcRate          Float    @default(0)
  checkoutRate     Float    @default(0)
  cpp              Float    @default(0)
  roas             Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([accountId, level, campaignId, adsetId, adId, date])
}

model Setting {
  key   String @id
  value String
}

model AccountMapping {
  id          Int      @id @default(autoincrement())
  storeId     Int?
  fbAccountId String   @unique
  fbPageId    String?
  project     String?
  owner       String?
  name        String?
  mode        String?
  store       Store?   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  updatedAt   DateTime @updatedAt
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("member") // "admin" or "member"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invitation {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  token     String   @unique
  role      String   @default("member")
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Store {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  platform        String?          @default("shopline")
  shopline_token  String?
  shopify_token   String?
  shoplazza_token String?
  domain          String?
  visitors        Int              @default(0)
  timezone        String?          @default("GMT+8")
  status          String?          @default("active")
  mode            String?
  accounts        AdAccount[]
  accountMappings AccountMapping[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model MetaAccountMonitoring {
  accountId     String   @id
  accountName   String?
  status        Int?
  spendCap      Float?
  amountSpent   Float?
  balance       Float?
  currency      String?
  timezone      String?
  updatedAt     DateTime @updatedAt
}

model AdAccount {
  id              Int      @id @default(autoincrement())
  fb_account_id   String   @unique
  fb_account_name String?
  fb_access_token String?
  currency        String?
  timezone        String?
  status          String?
  storeId         Int?
  activityStatus  Int      @default(2)
  recentActivity90d Boolean @default(false)
  lastActivityCheckedAt DateTime?
  store           Store?    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  campaigns       Campaign[]
}

model Product {
  id          String   @id
  storeId     Int
  name        String
  sku         String
  category    String
  inventory   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id              String   @id
  storeId         Int
  productId       String
  revenue         Float    @default(0)
  profit          Float    @default(0)
  refunded        Boolean  @default(false)
  refundedAt      DateTime?
  orderId         String?
  orderTotal      Float?
  createdAt       DateTime @default(now())
  store_local_date String?
  paymentStatus    String?
  fulfillmentStatus String?

  created_at_utc      DateTime?
  store_timezone      String?
  store_local_datetime String?
}

model Campaign {
  id          String   @id
  accountId   String
  name        String
  region      String?
  status      String?
  adAccount   AdAccount? @relation(fields: [accountId], references: [fb_account_id], onDelete: Cascade)
  adSets      AdSet[]
}

model AdSet {
  id          String   @id
  campaignId  String
  accountId   String
  name        String
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ads         Ad[]
}

model Ad {
  id          String   @id
  adsetId     String
  campaignId  String
  accountId   String
  name        String
  creativeId  String?
  adSet       AdSet?    @relation(fields: [adsetId], references: [id], onDelete: Cascade)
  creative    AdCreative? @relation(fields: [creativeId], references: [creativeId], onDelete: SetNull)
}

model AdCreative {
  creativeId   String                     @id
  fbAccountId  String
  mediaType    String                     // IMAGE/VIDEO
  imageUrl     String?
  videoId      String?
  videoHash    String?
  imageHash    String?                    @unique
  storeId      Int?
  name         String?
  type         String?
  landingUrl   String?
  previewUrl   String?
  metaAssetId  String?
  hookRate     Float                      @default(0)
  ads          Ad[]
  performances CreativePerformanceDaily[]
}

model CreativePerformanceDaily {
  id               Int        @id @default(autoincrement())
  creativeId       String
  date             String
  spend            Float      @default(0)
  impressions      Int        @default(0)
  clicks           Int        @default(0)
  revenue          Float      @default(0)
  storeId          Int?
  creativeName     String?
  type             String?
  purchases        Int        @default(0)
  roas             Float      @default(0)
  ctr              Float      @default(0)
  cpc              Float      @default(0)
  cpm              Float      @default(0)
  frequency        Float      @default(0)
  hookRate         Float      @default(0)
  aiRiskStatus     String?
  trendStatus      String?
  aiSuggestion     String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  creative         AdCreative @relation(fields: [creativeId], references: [creativeId], onDelete: Cascade)

  @@unique([creativeId, date])
}

model ProductPerformanceDaily {
  id               Int      @id @default(autoincrement())
  date             String
  storeId          Int
  productId        String
  productName      String
  sku              String
  category         String
  revenue          Float    @default(0)
  orders           Int      @default(0)
  profit           Float    @default(0)
  adSpend          Float    @default(0)
  productRoas      Float    @default(0)
  profitRoas       Float    @default(0)
  ctr              Float    @default(0)
  cpc              Float    @default(0)
  cpm              Float    @default(0)
  frequency        Float    @default(0)
  refundRate       Float    @default(0)
  inventory        Int      @default(0)
  topRegion        String?
  topCampaign      String?
  topCreative      String?
  aiRiskStatus     String?
  trendStatus      String?
  aiSuggestion     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([storeId, productId, date])
}

model AiProvider {
  id                   String   @id @default(uuid())
  provider             String   @unique
  displayName          String
  apiKeyEncrypted      String?
  defaultChatModel     String?
  defaultAnalysisModel String?
  defaultCreativeModel String?
  enabled              Boolean  @default(true)
  priority             Int      @default(100)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model AiConversation {
  id        String   @id @default(uuid())
  title     String
  context   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  AiMessage[]
}

model AiMessage {
  id             String          @id @default(uuid())
  conversationId String
  role           String
  content        String
  metadata       String?
  createdAt      DateTime        @default(now())
  conversation   AiConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model SyncLog {
  id             String   @id @default(uuid())
  type           String
  status         String
  startedAt      DateTime @default(now())
  finishedAt     DateTime?
  recordsFetched Int?
  recordsSaved   Int?
  adAccountId    String?
  storeId        String?
  rangeStart     String?
  rangeEnd       String?
  metadata       String?
  error          String?

  taskType       String?
  sourceType     String?
  errorCode      String?
  errorMessage   String?
  fbtraceId      String?
  triggeredBy    String?
  parentTaskId   String?
  taskChainId    String?
}

model DailySummary {
  id           Int      @id @default(autoincrement())
  scope        String   // "dashboard" | "store" | "ad_account" | "campaign" | "adset" | "ad" | "country" | "product"
  scopeId      String   // target ID (e.g. store_id or account_id or "all")
  date         String   // YYYY-MM-DD or timeframe (e.g. "7d", "30d")
  revenue      Float    @default(0)
  spend        Float    @default(0)
  orders       Int      @default(0)
  clicks       Int      @default(0)
  impressions  Int      @default(0)
  roas         Float    @default(0)
  metaRoas     Float    @default(0)
  metadata     String?  // JSON context if needed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([scope, scopeId, date])
}

model AiAnalysisReport {
  id                String               @id @default(uuid())
  type              String               // "media_buyer" | "creative" | "anomaly" | "chat_followup"
  entityType        String
  entityId          String
  dateRange         String?
  conclusion        String
  dataBasis         String?
  riskPoints        String?
  priority          Int                  @default(3)
  observationWindow String?
  model             String?
  metadata          String?
  createdAt         DateTime             @default(now())

  suggestions       AiActionSuggestion[]
}

model AiActionSuggestion {
  id                 String             @id @default(uuid())
  reportId           String
  action             String
  rationale          String
  priority           Int                @default(3)
  status             String             @default("pending") // "pending" | "accepted" | "rejected" | "done"
  executionChecklist String?
  metadata           String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  report             AiAnalysisReport   @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model FactMetaPerformance {
  id             Int      @id @default(autoincrement())
  date           String
  level          String   // "account" | "campaign" | "adset" | "ad"
  account_id     String
  campaign_id    String   @default("")
  adset_id       String   @default("")
  ad_id          String   @default("")
  creative_id    String   @default("")
  entity_id      String
  spend          Float    @default(0)
  impressions    Int      @default(0)
  clicks         Int      @default(0)
  ctr            Float    @default(0)
  cpc            Float    @default(0)
  cpm            Float    @default(0)
  purchases      Int      @default(0)
  purchase_value Float    @default(0)
  roas           Float    @default(0)
  currency       String   @default("USD")
  synced_at      DateTime @default(now())
  raw_payload    String?

  @@unique([date, level, account_id, entity_id])
}

model FactAudienceBreakdown {
  id                        Int      @id @default(autoincrement())
  date                      String   // YYYY-MM-DD
  level                     String   @default("account")   // "account" | "campaign" | "adset" | "ad"
  account_id                String
  campaign_id               String   @default("")
  adset_id                  String   @default("")
  ad_id                     String   @default("")
  dimension_type            String   // "country" | "region" | "age" | "gender" | "publisher_platform" | "impression_device"
  dimension_value           String   // e.g., "US", "California", "18-24", "female", "instagram", "android_smartphone"
  dimension_value_secondary String   @default("")          // For any combination dimensions if needed
  spend                     Float    @default(0)
  impressions               Int      @default(0)
  clicks                    Int      @default(0)
  purchases                 Int      @default(0)
  purchase_value            Float    @default(0)
  synced_at                 DateTime @default(now())
  raw_payload               String?

  @@unique([date, level, account_id, dimension_type, dimension_value, dimension_value_secondary, campaign_id, adset_id, ad_id])
}


